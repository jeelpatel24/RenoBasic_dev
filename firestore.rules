rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin check: uses the role field in the users collection
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      allow read: if isAuthenticated() && userId != request.auth.uid;
      allow read: if isAdmin();
      // Users can create/update their own doc — NO delete (only admin can delete)
      allow create, update: if request.auth.uid == userId;
      // Admin can create, update, or delete any user
      allow create, update, delete: if isAdmin();
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      // Homeowners can create projects for themselves only
      allow create: if isAuthenticated() &&
                       request.resource.data.homeownerUid == request.auth.uid;
      // Homeowners can update OR delete their own projects
      allow update, delete: if isAuthenticated() &&
                               resource.data.homeownerUid == request.auth.uid;
      // Admin can create, update, or delete any project
      allow create, update, delete: if isAdmin();
    }

    // Unlocks collection
    match /unlocks/{unlockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                       request.resource.data.contractorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.contractorUid;
      allow read: if isAdmin();
      // Clients may only create unlock transactions for themselves.
      // purchase/refund records are written by the Stripe webhook via Admin SDK
      // (which bypasses rules entirely) — clients cannot forge those types.
      allow create: if isAuthenticated() &&
                       request.resource.data.contractorUid == request.auth.uid &&
                       request.resource.data.type == 'unlock';
      allow write: if isAdmin();
    }

    // Conversations collection
    match /conversations/{conversationId} {
      // Participants or admin can read
      allow read: if isAuthenticated() &&
                     (request.auth.uid == resource.data.homeownerUid ||
                      request.auth.uid == resource.data.contractorUid ||
                      isAdmin());
      // Participants or admin can update (e.g. lastMessage, messageCount)
      allow update: if isAuthenticated() &&
                       (request.auth.uid == resource.data.homeownerUid ||
                        request.auth.uid == resource.data.contractorUid ||
                        isAdmin());
      // Either participant can create a conversation
      allow create: if isAuthenticated() &&
                       (request.resource.data.contractorUid == request.auth.uid ||
                        request.resource.data.homeownerUid == request.auth.uid);
      // Either participant or admin can delete a conversation
      allow delete: if isAuthenticated() &&
                       (request.auth.uid == resource.data.homeownerUid ||
                        request.auth.uid == resource.data.contractorUid ||
                        isAdmin());

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                       (request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.homeownerUid ||
                        request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.contractorUid ||
                        isAdmin());
        allow create: if isAuthenticated() &&
                         request.resource.data.senderId == request.auth.uid &&
                         (request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.homeownerUid ||
                          request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.contractorUid);
        // Participants can update (mark as read) or delete messages
        allow update, delete: if isAuthenticated() &&
                                  (request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.homeownerUid ||
                                   request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.contractorUid ||
                                   isAdmin());
      }
    }

    // Bids collection
    match /bids/{bidId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                       request.auth.uid == request.resource.data.contractorUid;
      // Homeowners can update ONLY the status and updatedAt fields on bids for
      // their own projects. status must be 'accepted' or 'rejected' — it cannot
      // be set back to 'submitted'. The affectedKeys() check prevents overwriting
      // any contractor-submitted fields (totalCost, lineItems, notes, etc.).
      allow update: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) &&
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.homeownerUid == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                       request.resource.data.status in ['accepted', 'rejected'];
      // Contractors can withdraw (delete) their own submitted bids only
      allow delete: if isAuthenticated() &&
                       resource.data.contractorUid == request.auth.uid &&
                       resource.data.status == "submitted";
      // Homeowners can delete any bid on their own project (e.g. when deleting the project)
      allow delete: if isAuthenticated() &&
                       exists(/databases/$(database)/documents/projects/$(resource.data.projectId)) &&
                       get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.homeownerUid == request.auth.uid;
      // Admin can do all
      allow write: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                     request.auth.uid == resource.data.recipientUid;
      allow read: if isAdmin();
      allow update: if isAuthenticated() &&
                       request.auth.uid == resource.data.recipientUid;
      allow delete: if isAuthenticated() &&
                       request.auth.uid == resource.data.recipientUid;
      allow create: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Settings (admin-managed only)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
                       request.resource.data.homeownerUid == request.auth.uid;
      // Only admin can modify or delete reviews
      allow update, delete: if isAdmin();
    }

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
